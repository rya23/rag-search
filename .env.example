# LLM Providers
GROQ_API_KEY=
HUGGING_FACE_TOKEN=
HF_TOKEN=
FAST_ROUTER_KEY=

# ChromaDB Cloud
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_COLLECTION=                     # deprecated, kept for reference
CHROMA_COLLECTION_768D=               # 768d collection name (existing)
CHROMA_COLLECTION_128D=               # 128d collection name (new, requires re-ingest)
EMBEDDING_MODEL=
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_QUALITY_THRESHOLD=0.3

# LLM Model name
LLM_MODEL=

# PostgreSQL / Supabase
user=
password=
host=
port=5432
dbname=postgres

# LangSmith Observability
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Frontend → Backend URL (used by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Docker Hub username (used by docker-compose image tags)
DOCKERHUB_USERNAME=
